{
  "buildCommand": "",
  "outputDirectory": ".",
  "installCommand": "",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "seabreezehomeservice.com" }],
      "destination": "https://www.seabreezehomeservice.com/$1",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/images/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Expires", "value": "Thu, 31 Dec 2037 23:55:55 GMT" }
      ]
    },
    {
      "source": "/brand_assets/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Expires", "value": "Thu, 31 Dec 2037 23:55:55 GMT" }
      ]
    },
    {
      "source": "/styles.css",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=0, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=86400, stale-while-revalidate=3600" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, s-maxage=86400, stale-while-revalidate=3600" }
      ]
    }
  ]
}
